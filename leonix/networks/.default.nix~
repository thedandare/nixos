    {
      address = "192.168.0.10";
      prefixLength = 24;
    }

  ];

  networking.defaultGateway = "192.168.0.1";
  networking.nameservers = [
    "192.168.0.2"
    "1.1.1.1"
    "181.213.132.5"
  ];

  #     "127.0.0.1"

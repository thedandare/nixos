#!/bin/sh
# ==============================================================================
# SCRIPT 1: tailscale_choose_ip.sh (Orquestrador Principal Corrigido)
# ==============================================================================
export ESCDELAY=0


# Tema customizado: Fundo Azul Marinho (blue) com Destaques e Botoes em Violeta (brightmagenta)
# ==============================================================================
# SUB-ROTINA POSIX: GERADOR DE CORES ALEATÓRIAS (ANTI-BASHISMO)
# ==============================================================================
sortear_cor_aleatoria() {
    # Lista estrita de cores homologadas de terminal aceitas pela biblioteca newt
    LISTA_CORES="black red green brown blue magenta cyan lightgrey darkgrey yellow white"

    # Extrai um numero inteiro aleatorio de 1 a 11 lendo a entropia do kernel (/dev/urandom)
    # O 'od' transforma os bytes brutos em decimal e o modulo '% 11' limita o escopo
    INDICE=$(head -c 2 /dev/urandom | od -An -N2 -i | awk '{print ($1 % 11) + 1}')

    # Pesca a palavra-chave correspondente na lista de strings usando o cut posicional
    echo "$LISTA_CORES" | cut -d' ' -f"$INDICE"
}

# Executa o sorteio individual para o texto e para o preenchimento
COR_TXT=$(sortear_cor_aleatoria)
COR_FND=$(sortear_cor_aleatoria)

# FAIL-SAFE: Se o sorteio gerar cores iguais (invisibilidade), força contraste imediato
if [ "$COR_TXT" = "$COR_FND" ]; then
    COR_TXT="white"
    COR_FND="blue"
fi

  # root=black,black
# Injeta os pares sorteados dinamicamente na matriz de layout do whiptail
export NEWT_COLORS="
  # root=black,black
  root=${COR_FND},${COR_TXT}
  window=${COR_TXT},${COR_FND}
  border=white,${COR_FND}
  shadow=black,black
  title=white,${COR_FND}
  textbox=${COR_TXT},${COR_FND}
  button=white,black
  actbutton=black,white
  checkbox=${COR_TXT},${COR_FND}
  actcheckbox=black,white
  listbox=${COR_TXT},${COR_FND}
  actlistbox=black,white
  label=white,${COR_FND}
"


clear

for comando in whiptail jq ping tailscale; do
    if ! command -v "$comando" >/dev/null 2>&1; then
        case "$comando" in ping) p_apt="iputils-ping" ;; *) p_apt="$comando" ;; esac
        sudo apt-get update -y && sudo apt-get install -y "$p_apt"
    fi
done

JSON_DATA=$(sudo tailscale status --json)
if [ -z "$JSON_DATA" ]; then
    echo "[ERRO CRITICO] Falha na comunacao com o daemon do Tailscale."
    exit 1
fi

TMP_MENU="/tmp/ts_menu.$$"
TMP_DETAILS="/tmp/ts_details.$$"

# ==============================================================================
# BIND DO CTRL+C (SIGINT): ENCERRAMENTO SANITÁRIO DO PAINEL
# ==============================================================================
encerrar_via_ctrl_c() {
    # Restaura o cursor e limpa o terminal para o operador nao ficar com a tela travada
    clear
    echo ""
    echo "[AVISO] Execucao interrompida pelo operador via Ctrl+C."
    echo "[INFO] Desalocando buffers e restaurando ambiente..."

    # Apaga cirurgicamente os arquivos temporarios criados por esta sessao (PID $$)
    rm -f "/tmp/ts_menu.$$" "/tmp/ts_details.$$" "/tmp/ts_flow.$$" "/tmp/ts_livres.$$" 2>/dev/null
    rm -f /tmp/ts_data.*.$$ 2>/dev/null

    echo "[SUCCESS] Sistema liberado de forma sanitaria."
    exit 130  # Codigo padrao do Linux para comandos interrompidos por SIGINT
}

# Vincula o sinal SIGINT (Ctrl+C) e o SIGTERM (Sinal de encerramento do sistema)
trap 'encerrar_via_ctrl_c' INT TERM


export JSON_DATA TMP_MENU TMP_DETAILS
trap 'rm -f "$TMP_MENU" "$TMP_DETAILS" /tmp/ts_data.*' EXIT INT TERM
# ==============================================================================
# FASE 2: MÁQUINA DE ESTADOS REESTRUTURADA (FLUXO DIRETO)
# ==============================================================================
TELA=1

while [ "$TELA" -ne 0 ]; do
    case "$TELA" in
        1)
            OPCOES=$(whiptail --title 'Painel Tailscale - Filtros' \
                --ok-button 'Prosseguir' \
                --cancel-button 'Sair' \
                --checklist 'Selecione os parametros de exibicao (Espaco para marcar):\n\n[ESC para Sair]' \
                13 68 3 \
                'IPV6' 'Exibir IPs no padrao IPv6' OFF \
                'ONLINE_ONLY' 'Ocultar dispositivos offline' OFF \
                3>&1 1>&2 2>&3)

            if [ $? -eq 1 ] || [ $? -eq 255 ]; then
                TELA=0
            else
                echo "$OPCOES" > "/tmp/ts_data.opts.$$"
                TELA=2
            fi
            ;;

        2)
            # Roda a listagem. Se o operador selecionar um dispositivo, o Script 2 deve retornar status 3
            ./tailscale_sub_module_menu.sh "$TMP_MENU" "$$"
            STATUS_TELA2=$?

            if [ "$STATUS_TELA2" -eq 1 ]; then
                TELA=1  # Botão Voltar ou ESC retorna para os Filtros
            elif [ "$STATUS_TELA2" -eq 3 ]; then
                TELA=3  # Sucesso: Avança direto para a digitação de IP
            else
                TELA=0  # Aborta em caso de qualquer outra falha
            fi
            ;;

        3)
            # Garante a permissao de execucao no sub-modulo de input manual
            chmod +x ./tailscale_sub_module_actions.sh 2>/dev/null

            # Executa a caixa de dialogo de IP direto na TTY real do console
            ./tailscale_sub_module_actions.sh "$TMP_DETAILS" "$$" < /dev/tty > /dev/tty 2>&1
            STATUS_TELA3=$?

            # Trata o retorno do Script 3 para decidir se volta para a lista ou finaliza
            if [ "$STATUS_TELA3" -eq 3 ] || [ "$STATUS_TELA3" -eq 1 ] || [ "$STATUS_TELA3" -eq 255 ]; then
                TELA=2  # Cancelou ou concluiu o InputBox, volta de forma limpa para a lista de nós
            elif [ "$STATUS_TELA3" -eq 0 ]; then
                TELA=0  # Sucesso absoluto na API da Tailscale, finaliza o painel para subir o cluster
            else
                TELA=2  # Fallback de segurança
            fi
            ;;
    esac
done


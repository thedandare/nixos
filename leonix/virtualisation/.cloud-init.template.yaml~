write_files:
  - path: /etc/sysctl.d/99-kubernetes.conf
    permissions: '0644'
    content: |
      net.ipv4.ip_forward = 1
      net.bridge.bridge-nf-call-iptables = 0
      net.bridge.bridge-nf-call-ip6tables = 0

  # 🧬 INJEÇÃO IMUTÁVEL DE FLAGS DO KUBELET (Fix de QoS para Kernel 7/LXD)
  # =========================================================================
  # Essa pasta aceita aspas duplas normais do YAML e resiste ao 'microk8s join'
  # - path: /var/snap/microk8s/common/args.d/kubelet
  #   permissions: '0644'
  #   content: |
  #     --protect-kernel-defaults=false
  #     --enforce-node-allocatable=""
  #     --cgroup-driver=systemd


# --cni-conf-dir=/var/snap/microk8s/current/args/cni-network
# --cgroups-per-qos=false


  # 🔌 INJEÇÃO IMUTÁVEL DE FLAGS DO PROXY (Fix de compatibilidade nftables)
  # =========================================================================
  # - path: /var/snap/microk8s/common/args.d/kube-proxy
  #   permissions: '0644'
  #   content: |
  #     --proxy-mode=iptables

  # 🔑 SCRIPT DO TAILSCALE BLINDADO CONTRA ERROS DE ESCAPE (BASE64)
  # =========================================================================
  - path: /usr/local/bin/autoconnect-tailscale.sh
    permissions: '0755'
    encoding: b64
    content: INJECT_TAILSCALE_B64_HERE

  # 🌐 FIX AUTODETECÇÃO DE REDE CALICO: Força o uso estrito do IP do Tailscale
  # =========================================================================
  # Impede o Calico de anunciar o IP local da eth0/br0 e o amarra na malha 100.x.x.x
  - path: /var/snap/microk8s/common/args.d/calico-env
    permissions: '0644'
    content: |
      IP_AUTODETECTION_METHOD=skip-interface=tailscale0

runcmd:
  # 1. Instalação do snapd e ferramentas básicas
  - apt-get update
  - apt install --reinstall util-linux
  - apt-get install -y snapd jq curl iptables net-tools

  # 🛠️ FIX COMPATIBILIDADE NIXOS: Força o uso do NFTables moderno (Kernel NixOS não tem iptables antigo)
  - update-alternatives --set iptables /usr/sbin/iptables-nft || true
  - update-alternatives --set ip6tables /usr/sbin/ip6tables-nft || true
  - update-alternatives --set arptables /usr/sbin/arptables-nft || true
  - update-alternatives --set ebtables /usr/sbin/ebtables-nft || true

  # 2. Inicialização forçada do Snapd
  - systemctl unmask snapd.service snapd.socket
  - systemctl enable snapd.service snapd.socket
  - systemctl start snapd.service snapd.socket

  # 2.1. Aguarda o Socket do Snapd responder
  - |
    for i in {1..15}; do
      if snap version >/dev/null 2>&1; then
        echo "Snapd respondendo com sucesso!"
        break
      fi
      echo "Aguardando inicialização do socket do snapd (Tentativa $i/15)..."
      systemctl start snapd.socket
      sleep 2
    done


  # 3. Instalação do Tailscale via script oficial
  - curl -fsSL https://tailscale.com/install.sh | sh

  # Executa o script isolado que foi decodificado perfeitamente sem problemas de aspas
  - /usr/local/bin/autoconnect-tailscale.sh



  # 5. Instalação estável do MicroK8s (Sem o snap install core redundante)
  - snap install microk8s --channel=1.36/stable --classic
  - sudo snap install microceph --channel=latest/stable


  - snap wait system seed.loaded

  # 5. Correções de Cgroup, QoS (Fix de Crash no LXD) e CNI antes de reservar caminhos
  - sed -i 's/snapshotter = "${SNAPSHOTTER}"/snapshotter = "overlayfs"/g' /var/snap/microk8s/current/args/containerd-template.toml
  #
  # # Injeção blindada de flags usando o escape '--' obrigatório do grep para não dar erro de opção inválida
  # - grep -qxF -- '--cgroup-driver=systemd' ${SNAP_DATA}/args/kubelet || echo '--cgroup-driver=systemd' >> ${SNAP_DATA}/args/kubelet
  # - grep -qxF -- '--cni-conf-dir=${SNAP_DATA}/args/cni-network' ${SNAP_DATA}/args/kubelet || echo '--cni-conf-dir=${SNAP_DATA}/args/cni-network' >> ${SNAP_DATA}/args/kubelet
  # - grep -qxF -- '--cgroups-per-qos=false' ${SNAP_DATA}/args/kubelet || echo '--cgroups-per-qos=false' >> ${SNAP_DATA}/args/kubelet
  # - grep -qxF -- '--protect-kernel-defaults=true' ${SNAP_DATA}/args/kubelet || echo '--protect-kernel-defaults=true' >> ${SNAP_DATA}/args/kubelet
  # - grep -qxF -- '--enforce-node-allocatable=""' ${SNAP_DATA}/args/kubelet || echo '--enforce-node-allocatable=""' >> ${SNAP_DATA}/args/kubelet
  # - grep -qxF -- '--proxy-mode=iptables' ${SNAP_DATA}/args/kube-proxy || echo '--proxy-mode=iptables' >> ${SNAP_DATA}/args/kube-proxy

  # 🛠️ FIX DO KINE: Eleva limites de arquivos abertos (Evita erro gRPC Closed Connection no SQLite)
  - prlimit --pid=$$ --nofile=1048576:1048576 || true
  - mkdir -p /etc/systemd/system/snap.microk8s.daemon-kubelite.service.d
  - |
    cat <<EOF > /etc/systemd/system/snap.microk8s.daemon-kubelite.service.d/override.conf
    [Service]
    LimitNOFILE=1048576
    LimitNPROC=512000
    EOF
  - systemctl daemon-reload
  - rm -f /var/snap/microk8s/current/var/kubernetes/backend/kine.sock
  - chmod -R 777 /var/snap/microk8s/current/var/kubernetes/backend/

  # 6. Atualiza rede do Host e segura atualizações automáticas do snap
  - sysctl --system
  - ln -sf /run/systemd/resolve/resolv.conf /etc/resolv.conf || true
  - snap set system refresh.hold=forever

  # 7. Aplica os parâmetros reiniciando os daemons do MicroK8s
  - snap restart microk8s.daemon-containerd
  - snap restart microk8s.daemon-kubelite




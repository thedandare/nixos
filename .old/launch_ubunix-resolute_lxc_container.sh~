#!/bin/sh

# 1. Cria a receita cloud-init pura para o Ubuntu
cat << 'EOF' > nix-config.yaml
#cloud-config
apt_update: true
apt_upgrade: true

packages:
  - curl
  - git
  - xz-utils
  - kubelet
  - kubeadm
  - kubectl
  - flannel

runcmd:
  - echo -e "\033[7;34m # 1. Cria diretório do Nix com permissões corretas  \033[0m]"
  - mkdir -p /nix && chown root:root /nix && chmod 0755 /nix
  - mv monitorar-nix.sh monitorar-nix.sh.old
  - mv nix-config.yaml nix-config.yaml.old
  - export HOME=/root

  - echo -e "\033[7;34m # 2. Executa o instalador do Nix oficial (Multi-user daemon recomendado para Ubuntu)  \033[0m]"
  - |
    cat << 'SCRIPT_EOF' > instalar_nix.sh
    #!/bin/sh
    curl --proto '=https' --tlsv1.2 -L https://nixos.org/nix/install | sh -s -- --daemon --yes
    SCRIPT_EOF
  - chmod +x instalar_nix.sh
  - instalar_nix.sh >> nix-install.log 2>&1

  - echo -e "\033[7;34m # 3. Carrega o ambiente do Nix no cloud-init  \033[0m]"
  - . /etc/profile.d/nix.sh

  - echo -e "\033[7;34m # 4. Ativa o suporte a Flakes  \033[0m]"
  - mkdir -p /root/.config/nix
  - echo "experimental-features = nix-command flakes" >> /root/.config/nix/nix.conf

  - echo -e "\033[7;34m # 5. Configuração do Home Manager  \033[0m]"
  - mkdir -p /root/.config/home-manager
  - |
    cat << 'INNER_EOF' > /root/.config/home-manager/flake.nix
    {
      description = "Home Manager Automatizado";
      inputs = {
        nixpkgs.url = "github:nixos/nixpkgs/nixos-unstable";
        home-manager = {
          url = "github:nix-community/home-manager";
          inputs.nixpkgs.follows = "nixpkgs";
        };
      };
      outputs = { nixpkgs, home-manager, ... }: {
        homeConfigurations."root" = home-manager.lib.homeManagerConfiguration {
          pkgs = nixpkgs.legacyPackages.x86_64-linux;
          modules = [ ./home.nix ];
        };
      };
    }
    INNER_EOF
  - |
    cat << 'INNER_EOF' > /root/.config/home-manager/home.nix
    { pkgs, ... }: {
      home.username = "root";
      home.homeDirectory = "/root";
      home.stateVersion = "24.11";
      home.packages = [
        pkgs.htop
        pkgs.turbovnc
      ];
      programs.home-manager.enable = true;
    }
    INNER_EOF


  - cd /root/.config/home-manager && git init
  - cd /root/.config/home-manager && git add flake.nix home.nix

  - echo -e "\033[7;35m # 6. Ativa o ambiente declarativo usando o binário absoluto do Nix recém-instalado  \033[0m]"
  - sudo su
  - /nix/var/nix/profiles/default/bin/nix run github:nix-community/home-manager -- switch --flake /root/.config/home-manager/#root >> nix-install.log 2>&1

  - echo -e "\033[7;33m # 7. Garante persistência dos caminhos para acessos via SSH/Console  \033[0m]"
  - echo 'if [ -f /etc/profile.d/nix.sh ]; then . /etc/profile.d/nix.sh; fi' >> /etc/profile
  - echo 'export PATH=$HOME/.nix-profile/bin:/nix/var/nix/profiles/default/bin:$PATH' >> /root/.bashrc

  - echo -e "\033[7;32m # 8. Rede tailscale  \033[0m]"
  - echo "Iniciando instalacao do Tailscale" >> /root/microk8s-init.log
  - curl -fsSL https://tailscale.com/install.sh | sh
  - sudo tailscale up --auth-key=tskey-auth-k2zo4sHucP11CNTRL-8AcxzcxzGh7Bcvq9aVXsh7PT3dF3u7GXd

  - echo -e "\033[7,33,] # 9.  MicroK8s via Snap \033[0m]"
  - echo "Iniciando instalacao do MicroK8s..." >> /root/microk8s-init.log
  - snap install microk8s --classic --channel=1.30/stable >> /root/microk8s-init.log 2>&1

  - echo -e "\033[7;34m # 10. Correções de Kernel e inotify (Evita falhas do dqlite)
  - mkdir -p /usr/local/lib/sysctl.d/
  - mkdir -p /etc/sysctl.d/
  - |
    cat << 'EOF' > /etc/sysctl.d/99-kubernetes-inotify.conf
    fs.inotify.max_user_instances=8192
    fs.inotify.max_user_watches=1048576
    EOF
  - sysctl --system >> /root/microk8s-init.log 2>&1

  - echo -e "\033[7;34m # 11. Script de provisionamento dinâmico baseado no IP do Tailscale  \033[0m]"
  - |
    cat << 'EOF' > /usr/local/bin/configure-microk8s-tailscale.sh
    #!/bin/bash
    set -e

    LOG="/root/microk8s-tailscale.log"
    echo "Aguardando a interface tailscale0 subir..." >> $LOG

    # Aguarda até que o IP do Tailscale esteja disponível
    TAILSCALE_IP=""
    for i in {1..30}; do
        TAILSCALE_IP=$(ip -4 addr show dev tailscale0 2>/dev/null | grep -oP '(?<=inet)+(\.+){3}') || true
        if [ ! -z "$TAILSCALE_IP" ]; then
            echo "IP do Tailscale encontrado: $TAILSCALE_IP" >> $LOG
            break
        fi
        sleep 5
    done

    if [ -z "$TAILSCALE_IP" ]; then
        echo "Erro: Interface tailscale0 nao obteve IP a tempo." >> $LOG
        exit 1
    fi

    echo "Interrompendo MicroK8s para aplicar configuracoes..." >> $LOG
    /snap/bin/microk8s stop

    SNAP_DATA_PATH="/var/snap/microk8s/current"

    # A. Injeta argumentos no dqlite
    if ! grep -q "--listen=" "$SNAP_DATA_PATH/args/k8s-dqlite"; then
        echo "--listen=$TAILSCALE_IP:19001" >> "$SNAP_DATA_PATH/args/k8s-dqlite"
    else
        sed -i "s/--listen=.*/--listen=$TAILSCALE_IP:19001/" "$SNAP_DATA_PATH/args/k8s-dqlite"
    fi

    # B. Cria e ajusta os arquivos de backend dqlite
    mkdir -p "$SNAP_DATA_PATH/var/kubernetes/backend"
    echo "Address: $TAILSCALE_IP:19001" > "$SNAP_DATA_PATH/var/kubernetes/backend/localnode.yaml"

    cat << BACKEND_EOF > "$SNAP_DATA_PATH/var/kubernetes/backend/cluster.yaml"
    - Address: $TAILSCALE_IP:19001
    BACKEND_EOF

    # C. Configura o Kubelet para anunciar o IP correto
    if ! grep -q "--node-ip=" "$SNAP_DATA_PATH/args/kubelet"; then
        echo "--node-ip=$TAILSCALE_IP" >> "$SNAP_DATA_PATH/args/kubelet"
    fi

    # D. Configura o API Server
    if ! grep -q "--advertise-address=" "$SNAP_DATA_PATH/args/kube-apiserver"; then
        echo "--advertise-address=$TAILSCALE_IP" >> "$SNAP_DATA_PATH/args/kube-apiserver"
        echo "--bind-address=0.0.0.0" >> "$SNAP_DATA_PATH/args/kube-apiserver"
    fi

    # E. Atualiza o template de Certificados da API
    if [ -f "$SNAP_DATA_PATH/certs/csr.conf.template" ]; then
        # Remove IP antigo se houver e adiciona o IP do Tailscale nos IPs alternativos
        sed -i "/10.38.74.101/d" "$SNAP_DATA_PATH/certs/csr.conf.template"
        if ! grep -q "$TAILSCALE_IP" "$SNAP_DATA_PATH/certs/csr.conf.template"; then
            sed -i "/\[ alt_names \]/a IP.100 = $TAILSCALE_IP" "$SNAP_DATA_PATH/certs/csr.conf.template"
        fi
    fi

    echo "Reiniciando daemons e aplicando alteracoes..." >> $LOG
    systemctl restart snapd.service
    /snap/bin/microk8s start
    /snap/bin/microk8s status --wait-ready >> $LOG 2>&1
    echo "Configuracao concluida com sucesso." >> $LOG
    EOF

  - chmod +x /usr/local/bin/configure-microk8s-tailscale.sh

  # 11. Executa a configuração em background para não travar o boot do cloud-init
  - /usr/local/bin/configure-microk8s-tailscale.sh &

EOF

# 2. Cria o monitor do log real do instalador do Nix
cat << 'EOF' > monitorar-nix.sh
#!/bin/sh
CONTAINER="ubun1x"
LOG_FILE="nix-install.log"

echo -e "\e[1;34m[==>] Iniciando monitoring do Nix no container Ubuntu: $CONTAINER\e[0m"

echo -n "Aguardando o container iniciar..."
until lxc info "$CONTAINER" 2>/dev/null | grep -q "Status: RUNNING"; do
    sleep 1
    echo -n "."
done
echo -e " \e[1;32m[OK]\e[0m"

echo -n "Aguardando o instalador do Nix iniciar..."
until lxc exec "$CONTAINER" -- test -f "$LOG_FILE" 2>/dev/null; do
    sleep 1
    echo -n "."
done
echo -e " \e[1;32m[Criado]\e[0m"

echo -e "\e[1;33m[==>] Lendo o progresso do Nix (Pressione CTRL+C para sair):\e[0m"
echo "----------------------------------------------------------------------"
lxc exec "$CONTAINER" -- tail -f "$LOG_FILE"
EOF

chmod +x monitorar-nix.sh

# 3. Executa a limpeza e configuração do repositório remoto do Ubuntu Minimal
echo "[==>] Limpando instâncias antigas..."
lxc delete ubun1x --force 2>/dev/null

# echo "[==>] Adicionando repositório remoto ubuntu-minimal (se não existir)..."
# lxc remote add ubuntu-minimal https://cloud-images.ubuntu.com/minimal/releases/ --protocol=simplestreams --accept-certificate 2>/dev/null || true
# sem a linha acima q deu o erro 'Error: Failed instance creation: Fetch project database object: Failed to fetch from "projects" table: Failed to fetch from "projects" table: Failed to fetch from "projects" table: sql: transaction has already been committed or rolled back'
# ele deve pegar  o padrao.

echo "[==>] Lançando novo container Ubuntu Minimal (Resolute)..."
lxc launch ubuntu-minimal:resolute ubun1x \
 	-c security.nesting=true \
  	-c security.privileged=true \
	--config=cloud-init.user-data="$(cat nix-config.yaml)"

# 4. Inicia o monitoramento
./monitorar-nix.sh

#!/usr/bin/env bash

# Interrompe o script se qualquer comando falhar
set -e

# Configurações do TPM e do ambiente
INDEX="0x1500000"
TCTI_DEV="device:/dev/tpmrm0"
READ_SCRIPT="./tpm_ler.sh"

clear
# Título estiloso usando o layout do gum
gum style --foreground 212 --border double --align center --width 50 "Gerenciador fTPM NVRAM" "NixOS Unstable + AMD Ryzen"

echo ""

# 1. Captura a string de forma oculta usando o prompt nativo do gum
USER_STRING=$(gum input --password --placeholder "Digite a senha/texto para o hardware...")

# Se o usuário deixar vazio ou der Ctrl+C, encerra
if [ -z "$USER_STRING" ]; then
    gum style --foreground 196 "Operação cancelada. Nenhum dado foi alterado."
    exit 0
fi

echo ""

# 2. Pergunta se deseja exibir a senha de forma limpa (Gera botões Sim/Não idênticos ao ecossistema Go)
# O gum confirm retorna 0 se escolher "Yes" e 1 se escolher "No"
set +e
gum confirm "Deseja visualizar a senha em texto claro na confirmação final?" --default=true
SHOW_STATUS=$?
set -e

# 3. Calcula o tamanho exato em bytes
BYTE_SIZE=$(echo -n "$USER_STRING" | wc -c)

# 4. Grava no fTPM usando a sintaxe validada oficial (-i -)
# Canaliza erros para não quebrar a interface visual
ERR_LOG=$(mktemp)
if ! echo -n "$USER_STRING" | sudo tpm2_nvwrite -T "$TCTI_DEV" -i - "$INDEX" 2>"$ERR_LOG"; then
    ERROR_MSG=$(cat "$ERR_LOG")
    gum style --foreground 196 --border rounded "Erro ao gravar no chip TPM:" "$ERROR_MSG"
    rm -f "$ERR_LOG"
    exit 1
fi
rm -f "$ERR_LOG"

# 5. Cria o script dinâmico de leitura
cat << EOF > "$READ_SCRIPT"
#!/usr/bin/env bash
echo -n "Dado lido do fTPM: "
sudo tpm2_nvread -T "$TCTI_DEV" -s $BYTE_SIZE $INDEX
echo ""
EOF
chmod +x "$READ_SCRIPT"

# 6. Faz o teste de leitura em tempo real
TEST_READ=$(sudo tpm2_nvread -T "$TCTI_DEV" -s "$BYTE_SIZE" "$INDEX")

# Se o status foi 0 (Sim), exibe o texto claro. Caso contrário, mascara.
if [ $SHOW_STATUS -eq 0 ]; then
    DISPLAY_TEXT="$TEST_READ"
else
    DISPLAY_TEXT=$(printf '*%.0s' $(seq 1 "$BYTE_SIZE"))
fi

echo ""

# 7. Janela de sucesso renderizada com LipGloss/Gum
gum style --foreground 46 --border rounded --padding "1 2" \
    "Gravação Concluída com Sucesso!" \
    "• Tamanho alocado: $BYTE_SIZE bytes" \
    "• Script de leitura gerado: $READ_SCRIPT" \
    "" \
    "[Dado retornado pelo fTPM]:" \
    "-> $DISPLAY_TEXT"

echo ""

#!/usr/bin/env bash

# Interrompe o script se houver erros comuns, mas isolamos os blocos críticos
set -e

INDEX="0x1500000"
TCTI_DEV="device:/dev/tpmrm0"
READ_SCRIPT="./tpm_ler.sh"
TEMP_BLOCK=$(mktemp)
TEMP_NEW_BLOCK=$(mktemp)
TEMP_RAW=$(mktemp)

# Limpeza automática de arquivos temporários ao sair
trap 'rm -f "$TEMP_BLOCK" "$TEMP_NEW_BLOCK" "$TEMP_RAW"' EXIT

clear
gum style --foreground 212 --border double --align center --width 50 "Banco de Dados fTPM NVRAM (2048 Bytes)"

echo ""

# 1. Captura a entrada inicial (Nome do segredo ou comando com ':')
INPUT_CMD=$(gum input --placeholder "Digite o nome do segredo ou comando (Ex: :l para listar)...")

# Se o usuário deixar vazio ou cancelar, sai sem erro
if [ -z "$INPUT_CMD" ]; then
    echo "Operação cancelada."
    exit 0
fi

# 2. INTERCEPTADOR DE COMANDOS CLI (Se começar com ':')
if [[ "$INPUT_CMD" =~ ^: ]]; then
    case "$INPUT_CMD" in
        :l|:list)
            echo "-> Buscando e decodificando dados do fTPM..."

            # Gravamos em arquivo temporário primeiro para EVITAR o aviso de "ignored null byte" do Bash
            sudo tpm2_nvread -T "$TCTI_DEV" -s 2048 "$INDEX" 2>/dev/null > "$TEMP_RAW" || true

            # Filtra apenas as linhas válidas com formato chave=valor
            tr -d '\000' < "$TEMP_RAW" | grep "=" > "$TEMP_BLOCK" || true

            # Extrai os nomes das chaves para alimentar o menu
            SAVED_KEYS=$(cut -d= -f1 < "$TEMP_BLOCK" || true)

            echo ""
            if [ -z "$SAVED_KEYS" ]; then
                gum style --foreground 220 --border rounded " O índice do fTPM está vazio " "Nenhum segredo no formato 'chave=valor' foi encontrado."
                exit 0
            fi

            # 3. GERA O MENU INTERATIVO COM O GUM CHOOSE
            gum style --foreground 212 "Selecione um segredo para revelar o valor:"
            SELECTED_KEY=$(echo "$SAVED_KEYS" | gum choose)

            # Se o usuário cancelar a seleção ou der Ctrl+C, sai limpo
            if [ -z "$SELECTED_KEY" ]; then
                echo "Nenhum segredo selecionado."
                exit 0
            fi

            # Busca o valor correspondente à chave selecionada dentro do arquivo temporário estruturado
            REVEALED_VAL=$(grep "^${SELECTED_KEY}=" "$TEMP_BLOCK" | cut -d= -f2- || true)

            echo ""
            gum style --foreground 46 --border rounded --padding "1 2" \
                "Chave Revelada do fTPM!" \
                "• Chave: $SELECTED_KEY" \
                "• Valor: $REVEALED_VAL"
            echo ""
            exit 0
            ;;
        *)
            gum style --foreground 196 "Erro: Comando '$INPUT_CMD' não reconhecido. Use :l ou :list."
            exit 1
            ;;
    esac
fi

# 4. SE NÃO FOR COMANDO, CONTINUA O FLUXO PADRÃO DE GRAVAÇÃO
KEY_NAME=$(echo "$INPUT_CMD" | tr -d '[:space:]=')

# Captura o valor do segredo em texto claro
SECRET_VAL=$(gum input --placeholder "Digite o valor/senha para guardar em '$KEY_NAME'...")
if [ -z "$SECRET_VAL" ]; then
    echo "Operação cancelada."
    exit 0
fi

echo ""
echo "-> Acessando o fTPM para atualizar a lista..."

# Lê o bloco atual do chip jogando para arquivo para evitar warnings
sudo tpm2_nvread -T "$TCTI_DEV" -s 2048 "$INDEX" 2>/dev/null > "$TEMP_RAW" || true
tr -d '\000' < "$TEMP_RAW" > "$TEMP_BLOCK" || true

# Remove a chave se ela já existia para evitar duplicatas na mesclagem
grep -v "^${KEY_NAME}=" "$TEMP_BLOCK" > "$TEMP_NEW_BLOCK" || true

# Adiciona o novo par de segredo na lista
echo "${KEY_NAME}=${SECRET_VAL}" >> "$TEMP_NEW_BLOCK"

# Valida se cabe nos 2048 bytes físicos do hardware
TOTAL_BYTES=$(wc -c < "$TEMP_NEW_BLOCK")
if [ "$TOTAL_BYTES" -gt 2048 ]; then
    gum style --foreground 196 "Erro: A lista excedeu o limite físico de 2048 bytes ($TOTAL_BYTES bytes)."
    exit 1
fi

# Grava de volta no fTPM
sudo tpm2_nvwrite -T "$TCTI_DEV" -i "$TEMP_NEW_BLOCK" "$INDEX"

# Atualiza o script auxiliar de leitura standalone
cat << 'EOF' > "$READ_SCRIPT"
#!/usr/bin/env bash
INDEX="0x1500000"
TCTI_DEV="device:/dev/tpmrm0"

if [ -z "$1" ]; then
    echo "Uso: $0 <nome_do_segredo>"
    echo "Segredos atualmente guardados no fTPM:"
    sudo tpm2_nvread -T "$TCTI_DEV" -s 2048 "$INDEX" 2>/dev/null | tr -d '\000' | grep "=" | cut -d= -f1 | sed 's/^/ - /'
    exit 0
fi

VALOR=$(sudo tpm2_nvread -T "$TCTI_DEV" -s 2048 "$INDEX" 2>/dev/null | tr -d '\000' | grep "^$1=" | cut -d= -f2-)

if [ -z "$VALOR" ]; then
    echo "Erro: Segredo '$1' não encontrado no hardware."
    exit 1
fi

echo "Chave: $1"
echo "Valor: $VALOR"
EOF
chmod +x "$READ_SCRIPT"

echo ""
gum style --foreground 46 --border rounded --padding "1 2" \
    "Sucesso! Segredo '$KEY_NAME' salvo de forma permanente." \
    "Espaço ocupado na NVRAM: $TOTAL_BYTES / 2048 bytes."

echo ""

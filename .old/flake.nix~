
      # Executa o login automático na rede mesh usando sua chave imutável


{
  description = "Configuracao 100% Declarativa da VM Ubuntu do MicroK8s via Flakes";

  inputs = {
    nixpkgs.url = "github:nixos/nixpkgs/nixos-unstable";
    home-manager = {
      url = "github:nix-community/home-manager";
      inputs.nixpkgs.follows = "nixpkgs";
    };
  };

  outputs = { nixpkgs, home-manager, ... }: {
    homeConfigurations."root-ubuntu" = home-manager.lib.homeManagerConfiguration {
      pkgs = nixpkgs.legacyPackages.x86_64-linux;
      modules = [
        ({ pkgs, ... }: {
          home.username = "root";
          home.homeDirectory = "/root";
          home.stateVersion = "24.11";

          # 1. Ferramentas essenciais declaradas via Nix
          home.packages = [
            pkgs.curl
            pkgs.git
            pkgs.htop
            pkgs.neovim
            pkgs.tailscale
            pkgs.gnvim
            pkgs.headlamp
            pkgs.turbovnc
          ];

          programs.bash.enable = true;
          programs.zsh.enable = true;
          programs.home-manager.enable = true;
          # 2. Arquivo de boot rc.local (Resolve AppArmor + Autostart do Tailscale)
          home.file."/etc/rc.local" = {
            text = ''
              #!/bin/bash
              # Garante que o AppArmor do MicroK8s carregue no boot
              apparmor_parser --add /var/lib/snapd/apparmor/profiles/snap.microk8s.*

              # Garante que o daemon do Tailscale esteja rodando
              systemctl start tailscaled

              # Autentica de forma automatica na rede Mesh (Substitua pela sua chave real se quiser)
                    tailscale up --authkey=tskey-auth-kxp3iGWNqv11CNTRL-fRKX2tJCSYUGZRWmj554ZULrEhstX8qK --accept-dns=true --accept-routes=true

            '';
            executable = true;
          };

          # 3. Correção do Containerd (Muda para "zfs" para destravar as imagens no seu LXD)
          home.file."/var/snap/microk8s/current/args/containerd.toml".text = ''
            version = 2
            root = "/var/snap/microk8s/common/var/lib/containerd"
            state = "/var/snap/microk8s/common/run/containerd"

            [plugins."io.containerd.grpc.v1.cri"]
              unpack_snapshotter = "zfs"
              snapshotter = "zfs"
              sandbox_image = "registry.k8s.io/pause:3.10"
          '';

          # 4. Seu Manifesto do LXD INTEGRO com todas as suas Chaves SSH, Redes e Perfis
          home.file.".config/lxd-preseed.yaml".text = ''
            config:
              cluster.https_address: 192.168.0.15:8443
              core.https_address: 192.168.0.15:8443
            networks:
            - config:
                ipv4.address: 10.38.74.1/24
                ipv4.nat: "true"
                ipv6.address: fd42:b99d:9e20:eaa8::1/64
                ipv6.nat: "true"
              name: lxdbr0
              type: bridge
              project: default
            - config:
                volatile.last_state.created: "false"
              name: lxdnet
              type: physical
              project: default
            storage_pools:
            - config: {}
              name: hda_nvme_zfs_pool
              driver: zfs
            storage_volumes: []
            profiles:
            - config:
                boot.autostart: "true"
                cloud-init.ssh-keys.profile-key-1: "root:ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAICs+sOj/1GK5exkDkCw7H7zmDapshfWaRn474qxZxSUY leo\r\n"
                cloud-init.ssh-keys.profile-key-2: |
                  root:ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIMGWvbEP/E0dh/xwtUVIuQrNDSz+G4TCLA+UMVpT0gLi root@ali
                cloud-init.ssh-keys.profile-key-3: |
                  root:ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIPlCOf70p6jujZf6ZdE7ugOQAPtpqteigxxaQb4RONs4 thedandare@gmail.com
                cloud-init.ssh-keys.profile-key-4: |
                  root:ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIO4x8pXKybfzCbc6IAd+HoPMW4vy3vT6ByGHM3uz4ApN leo@ali
                limits.memory: 5GiB
                linux.kernel_modules: ip_vs,ip_vs_rr,ip_vs_wrr,ip_vs_sh,ip_tables,ip6_tables,netlink_diag,nf_nat,overlay,br_netfilter
                raw.lxc: |
                  lxc.apparmor.profile=unconfined
                  lxc.mount.auto=proc:rw sys:rw cgroup:rw
                  lxc.cgroup.devices.allow=a
                  lxc.cap.drop=
                security.nesting: "true"
                security.privileged: "true"
              devices:
                eth0:
                  network: lxdbr0
                  type: nic
              name: MicroK8s
            - config:
                limits.cpu: "12"
                limits.memory: 4GiB
              devices:
                eth0:
                  name: eth0
                  network: lxdbr0
                  type: nic
                root:
                  path: /
                  pool: hda_nvme_zfs_pool
                  type: disk
              name: default
            - config:
                boot.autostart: "true"
                linux.kernel_modules: ip_vs,ip_vs_rr,ip_vs_wrr,ip_vs_sh,ip_tables,ip6_tables,netlink_diag,nf_nat,overlay,br_netfilter
                raw.lxc: |
                  lxc.apparmor.profile=unconfined
                  lxc.mount.auto=proc:rw sys:rw cgroup:rw
                  lxc.cgroup.devices.allow=a
                  lxc.cap.drop=
                security.nesting: "true"
                security.privileged: "true"
              devices:
                root:
                  path: /
                  pool: hda_nvme_zfs_pool
                  type: disk
              name: microk8s
            projects:
            - config:
                features.images: "true"
                features.networks: "true"
                features.networks.zones: "true"
                features.profiles: "true"
                features.storage.buckets: "true"
                features.storage.volumes: "true"
              name: default
          '';
        })
      ];
    };
  };
}


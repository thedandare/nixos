      "1" "Reiniciar Serviço" \
      "2" "Apenas Monitorar Logs" \
      "3" "Sair" 3>&1 1>&2 2>&3)

    # Processamento de fluxo baseado na variável
    case "\$ESCOLHA" in
      1)
        tmux split-window -v -p 45 "sudo systemctl restart \${serviceName} && sudo journalctl -u \${serviceName} -f"
        ;;
      2)
        tmux split-window -v -p 45 "sudo journalctl -u \${serviceName} -f -n 50"

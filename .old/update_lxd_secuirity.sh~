# Permite rodar containers dentro do container (Nesting)
lxc config set mk8s security.nesting true

# Torna o container privilegiado para acessar o kernel do host
lxc config set mk8s security.privileged true

# Desativa o bloqueio do AppArmor e libera módulos de rede
lxc config set mk8s raw.lxc "lxc.apparmor.profile=unconfined\nlxc.cap.drop=\nlxc.cgroup.devices.allow=a\nlxc.mount.auto=proc:rw sys:rw"

# Carrega os módulos de rede necessários no host
sudo modprobe ip_tables iptable_nat ip6_tables nf_nat overlay br_netfilter

# Reinicie o container para aplicar as mudanças
lxc restart mk8s

# Limpa a configuração antiga corrompida
lxc config unset mk8s raw.lxc

# Aplica a configuração com quebras de linha reais
lxc config set mk8s raw.lxc "lxc.apparmor.profile=unconfined
lxc.cap.drop=
lxc.cgroup.devices.allow=a
lxc.mount.auto=proc:rw sys:rw"

# Inicie o container novamente
lxc start mk8s
